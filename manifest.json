{
  "manifest_version": 3,
  "name": "API Key Exposure Auditor",
  "version": "1.10.0",
  "description": "Finds API keys leaked in your own web projects and audits their access and billing exposure. Self-project security.",
  "homepage_url": "https://github.com/hasif5/api-key-exposure-auditor",
  "minimum_chrome_version": "111",
  "permissions": [
    "storage",
    "webRequest",
    "tabs",
    "scripting",
    "downloads",
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/intercept.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/patterns.js", "content/content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "API Key Exposure Auditor",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
